{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "paths": {
      "*": ["./*"],
      "@shared/*": ["./shared/*"],
      "@renderer/*": ["./src/renderer/*"]
    },
    "lib": ["ESNext", "DOM"],
    "types": ["node"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*",
    "shared/**/*",
    "electron.vite.config.ts",
    "index.html"
  ]
}
