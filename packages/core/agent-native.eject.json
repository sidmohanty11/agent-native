{
  "manifestVersion": 1,
  "package": "@agent-native/core",
  "catalogs": [
    "remote-mcp-presets",
    "workspace-connections",
    "provider-api-definitions",
    "messaging-adapters",
    "setup-readiness-ui"
  ],
  "units": [
    {
      "id": "integration/remote-mcp-presets",
      "label": "Built-in remote MCP presets",
      "catalog": "remote-mcp-presets",
      "catalogItems": [
        "context7",
        "sentry",
        "notion",
        "granola",
        "semgrep",
        "linear",
        "atlassian",
        "supabase",
        "neon",
        "stripe",
        "cloudflare",
        "gitlab",
        "figma",
        "canva",
        "vercel",
        "github",
        "slack",
        "asana",
        "hubspot",
        "intercom",
        "monday",
        "webflow",
        "paypal",
        "box",
        "netlify",
        "zapier"
      ],
      "entrypoints": ["./client/resources"],
      "strategy": "source-copy",
      "sourceEntries": ["src/eject/remote-mcp-presets.ts"],
      "targetRoot": "app/integrations/agent-native/remote-mcp",
      "seam": "@agent-native/core/client/resources",
      "protectedImports": ["@agent-native/core/client/resources/runtime"],
      "dependencies": ["react"],
      "verification": ["pnpm typecheck"]
    },
    {
      "id": "integration/workspace-connections",
      "label": "Workspace connection providers",
      "catalog": "workspace-connections",
      "catalogItems": [
        "slack",
        "github",
        "figma",
        "notion",
        "gmail",
        "google_drive",
        "hubspot",
        "salesforce",
        "jira",
        "sentry",
        "granola",
        "clips",
        "generic"
      ],
      "entrypoints": ["./connections"],
      "strategy": "source-copy",
      "sourceEntries": ["src/eject/workspace-connections.ts"],
      "targetRoot": "app/integrations/agent-native/workspace-connections",
      "seam": "@agent-native/core/connections",
      "protectedImports": ["@agent-native/core/connections/runtime"],
      "verification": ["pnpm typecheck"]
    },
    {
      "id": "integration/provider-api-definitions",
      "label": "Provider API definitions",
      "catalog": "provider-api-definitions",
      "catalogItems": [
        "amplitude",
        "apollo",
        "bigquery",
        "clay",
        "commonroom",
        "dataforseo",
        "ga4",
        "gcloud",
        "github",
        "figma",
        "gmail",
        "gong",
        "google_calendar",
        "google_drive",
        "google_slides",
        "granola",
        "grafana",
        "hubspot",
        "salesforce",
        "jira",
        "mixpanel",
        "notion",
        "posthog",
        "prometheus",
        "pylon",
        "sentry",
        "slack",
        "stripe",
        "twitter"
      ],
      "entrypoints": ["./provider-api"],
      "strategy": "source-copy",
      "sourceEntries": ["src/eject/provider-api-definitions.ts"],
      "targetRoot": "app/integrations/agent-native/provider-api",
      "seam": "@agent-native/core/provider-api",
      "protectedImports": [
        "@agent-native/core/provider-api/runtime",
        "@agent-native/core/connections/runtime"
      ],
      "verification": ["pnpm typecheck"]
    },
    {
      "id": "integration/slack",
      "label": "Built-in messaging adapters",
      "catalog": "messaging-adapters",
      "catalogItems": [
        "slack",
        "telegram",
        "whatsapp",
        "microsoft-teams",
        "discord",
        "google-docs",
        "email"
      ],
      "entrypoints": ["./integrations"],
      "strategy": "source-copy",
      "sourceEntries": ["src/integrations/eject/messaging-adapters.ts"],
      "targetRoot": "server/agent-native-ejected",
      "protectedImports": ["@agent-native/core/integrations/runtime"],
      "verification": ["pnpm typecheck"]
    },
    {
      "id": "integration/setup-readiness-ui",
      "label": "Connection setup and readiness UI",
      "catalog": "setup-readiness-ui",
      "catalogItems": [
        "builder-connect-card",
        "provider-readiness-badge",
        "setup-connections-page"
      ],
      "entrypoints": ["./client/setup-connections"],
      "strategy": "source-copy",
      "sourceEntries": ["src/eject/setup-readiness-ui.tsx"],
      "targetRoot": "app/components/agent-native/setup-connections",
      "seam": "@agent-native/core/client/setup-connections",
      "protectedImports": [
        "@agent-native/core/client/setup-connections/runtime"
      ],
      "dependencies": ["react"],
      "verification": ["pnpm typecheck"]
    }
  ]
}
