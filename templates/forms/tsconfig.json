{
  "extends": "@agent-native/core/tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "*": ["./*"],
      "@/*": ["./app/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "include": [
    "app/**/*",
    "server/**/*",
    "shared/**/*",
    "react-router.config.ts",
    ".react-router/types/**/*",
    ".generated/**/*"
  ]
}
